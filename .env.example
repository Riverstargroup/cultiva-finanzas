# =============================================================================
# .env.example — Variables de entorno para Cultiva Finanzas (Semilla)
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (requerido para desarrollo local y produccion)
# Obtener en: https://app.supabase.com → Proyecto → Settings → API
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------------------
# Docker Compose / Supabase Local (solo desarrollo con docker compose)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=tu-password-seguro-de-postgres
JWT_SECRET=tu-jwt-secret-de-al-menos-32-caracteres-de-largo
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------------------
# AWS (requerido para scripts de despliegue)
# Configurar con: aws configure
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Variables usadas por scripts/deploy.sh y buildspec.yml
CULTIVA_S3_BUCKET=cultiva-finanzas-production-website-123456789012
CULTIVA_CF_ID=E1234ABCDEF5678

# ---------------------------------------------------------------------------
# Notificaciones (opcional)
# ---------------------------------------------------------------------------
NOTIFICATION_EMAIL=equipo@enactus.mx

# ---------------------------------------------------------------------------
# GitHub (para CodePipeline — solo necesario al desplegar CloudFormation)
# Crear en: https://github.com/settings/tokens (scope: repo)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=riverstargroup
GITHUB_REPO=cultiva-finanzas
GITHUB_BRANCH=main
