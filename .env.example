# =============================================================================
# .env.example — Variables de entorno para Semilla / Cultiva Finanzas
#
# Cómo usar:
#   cp .env.example .env
#   # Edita .env con los valores reales
#
# NUNCA subas el archivo .env al repositorio.
# Todos los secretos de CI/CD se configuran en GitHub → Settings → Secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase — REQUERIDO (desarrollo local y producción)
# Obtener en: https://app.supabase.com → tu proyecto → Settings → API
# ---------------------------------------------------------------------------

# URL pública del proyecto Supabase. Formato: https://<project-id>.supabase.co
# REQUERIDO — sin esto la app no puede conectarse a la base de datos.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima (publishable) — segura de exponer en el cliente.
# Llamada "anon key" o "publishable key" en el dashboard de Supabase.
# REQUERIDO — sin esto la app no puede autenticar usuarios.
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------------------
# Supabase CLI / Docker Compose — OPCIONAL
# Solo necesario si ejecutas `supabase start` o `docker compose up` localmente.
# ---------------------------------------------------------------------------

# Contraseña para la instancia local de PostgreSQL
# OPCIONAL — solo para desarrollo local con Docker
POSTGRES_PASSWORD=tu-password-seguro-de-postgres

# JWT secret para la instancia local de Supabase (mínimo 32 caracteres)
# OPCIONAL — solo para desarrollo local con Docker
JWT_SECRET=tu-jwt-secret-de-al-menos-32-caracteres-de-largo

# Clave de servicio (service_role) — NUNCA en el cliente, solo en scripts de servidor
# OPCIONAL — solo para scripts de administración
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------------------
# AWS — REQUERIDO para despliegue manual (scripts/deploy.sh)
# En CI/CD (GitHub Actions) estos valores van como secretos de repositorio,
# no como variables en .env. Configura locales con: aws configure
# ---------------------------------------------------------------------------

# Región de AWS donde vive el bucket S3 y la distribución CloudFront
# REQUERIDO para despliegue manual
AWS_REGION=us-east-1

# ID numérico de la cuenta AWS (12 dígitos)
# OPCIONAL — usado por CloudFormation
AWS_ACCOUNT_ID=123456789012

# Nombre del bucket S3 que sirve los archivos estáticos
# REQUERIDO para despliegue manual — en CI/CD usa el secret S3_BUCKET
CULTIVA_S3_BUCKET=semilla-hosting-<aws-account-id>

# ID de la distribución CloudFront (formato: E seguido de alfanuméricos)
# REQUERIDO para despliegue manual — en CI/CD usa el secret CF_DISTRIBUTION_ID
CULTIVA_CF_ID=EXXXXXXXXXXXX

# ---------------------------------------------------------------------------
# Notificaciones — OPCIONAL
# ---------------------------------------------------------------------------

# Email para alertas y notificaciones del sistema
NOTIFICATION_EMAIL=equipo@enactus.mx

# ---------------------------------------------------------------------------
# Nopalito Assistant / OpenRouter — SOLO BACKEND (Supabase Edge Functions)
# No usar prefijo VITE_; esta clave nunca debe llegar al navegador.
# Configurar en Supabase con:
#   supabase secrets set OPENROUTER_API_KEY=...
# ---------------------------------------------------------------------------

OPENROUTER_API_KEY=sk-or-v1-tu-clave-openrouter
OPENROUTER_API_KEY2=sk-or-v1-tu-clave-openrouter-fallback
NOPALITO_MODEL=openai/gpt-oss-120b:free
NOPALITO_FALLBACK_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# ---------------------------------------------------------------------------
# GitHub / CodePipeline — OPCIONAL
# Solo necesario si se despliega infraestructura CloudFormation con CodePipeline.
# En flujos normales con GitHub Actions esto NO se necesita.
# ---------------------------------------------------------------------------

# Token de GitHub con scope "repo" — crear en https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

GITHUB_OWNER=riverstargroup
GITHUB_REPO=cultiva-finanzas
GITHUB_BRANCH=main
